// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  date        DateTime
  location    String
  type        String // Workshop | Networking | Conference | Seminar
  isPast      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model NewsArticle {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  category    String
  author      String
  publishedAt DateTime @default(now())
}

model MemberApplication {
  id             String   @id @default(cuid())
  fullName       String
  email          String
  phone          String
  province       String
  discipline     String
  employer       String
  membershipType String
  referral       String?
  createdAt      DateTime @default(now())
}

model ContactInquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  createdAt DateTime @default(now())
}
